# FastAPI AI service — copy to .env and fill in real values

# Shared secret — must match AI_SERVICE_INTERNAL_KEY in backend .env
INTERNAL_API_KEY=change_me_to_a_long_random_secret

# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.0-flash-001

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ChromaDB Cloud (cloud.trychroma.com)
CHROMA_API_KEY=your_chromadb_api_key
CHROMA_TENANT=your_chromadb_tenant_id
CHROMA_DATABASE=your_chromadb_database_name

# Upstash Redis (upstash.com → Redis → REST API)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
